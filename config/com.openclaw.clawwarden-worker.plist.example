<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.openclaw.clawwarden-control-plane</string>
  <key>ProgramArguments</key>
  <array>
    <string>__PYTHON__</string>
    <string>__REPOSITORY__/scripts/control_plane.py</string>
    <string>daemon</string>
  </array>
  <key>KeepAlive</key>
  <true/>
  <key>RunAtLoad</key>
  <true/>
  <key>StandardOutPath</key>
  <string>__HOME__/.openclaw/logs/clawwarden-worker.stdout.log</string>
  <key>StandardErrorPath</key>
  <string>__HOME__/.openclaw/logs/clawwarden-worker.stderr.log</string>
</dict>
</plist>
